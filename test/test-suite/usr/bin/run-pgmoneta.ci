set -euo pipefail

echo "Setting up pgmoneta..."

chmod 700 /pgmoneta/
chown -R pgmoneta:pgmoneta /pgmoneta/

required_vars=("PG_PRIMARY_NAME" "PG_PRIMARY_PORT" "PG_REPL_USER_NAME" "PG_REPL_USER_PASSWORD")
for var in "${required_vars[@]}"; do
    if [ -z "${!var}" ]; then
        echo "ERROR: $var is not set!"
        exit 1
    fi
done

sed -i "s/PG_PRIMARY_NAME/$PG_PRIMARY_NAME/g" /tmp/pgmoneta.conf
sed -i "s/PG_PRIMARY_PORT/$PG_PRIMARY_PORT/g" /tmp/pgmoneta.conf
sed -i "s/PG_REPL_USER_NAME/$PG_REPL_USER_NAME/g" /tmp/pgmoneta.conf
sed -i "s/PG_REPL_USER_PASSWORD/$PG_REPL_USER_PASSWORD/g" /tmp/pgmoneta.conf

su - pgmoneta -c "cp /tmp/pgmoneta.conf /pgmoneta/pgmoneta.conf"

echo "Initializing pgmoneta..."
su - pgmoneta -c "pgmoneta-admin -f /pgmoneta/pgmoneta_admins.conf -U ${PG_REPL_USER_NAME} -P ${PG_REPL_USER_PASSWORD} user add"
su - pgmoneta -c "pgmoneta-admin -f /pgmoneta/pgmoneta_users.conf -U ${PG_REPL_USER_NAME} -P ${PG_REPL_USER_PASSWORD} user add"

su - pgmoneta -c "echo \"PATH=/usr/pgsql-18/bin:\$PATH\" > /home/pgmoneta/.bashrc"
su - pgmoneta -c "echo \"export PATH\" >> /home/pgmoneta/.bashrc"

echo "Setup complete!"

echo "Starting pgmoneta..."
exec su - pgmoneta -c "pgmoneta -c /pgmoneta/pgmoneta.conf -A /pgmoneta/pgmoneta_admins.conf -u /pgmoneta/pgmoneta_users.conf"